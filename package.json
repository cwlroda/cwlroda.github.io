{
  "private": true,
  "name": "cwlroda",
  "version": "1.0.0",
  "homepage": "https://cwlroda.github.io/",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "start": "vite",
    "dev": "vite",
    "build": "vite build && npm run build:snailstrail",
    "build:snailstrail": "npm --prefix snailstrail ci --prefer-offline --no-audit --no-fund && npm --prefix snailstrail run build && mkdir -p build/snailstrail && cp -R snailstrail/dist/. build/snailstrail/",
    "preview": "vite preview",
    "predeploy": "npm run build",
    "deploy": "gh-pages -b gh-pages -d build"
  },
  "dependencies": {
    "baseui": "^16.1.1",
    "chart.js": "^4.5.0",
    "react": "19.2.6",
    "react-chartjs-2": "^5.3.0",
    "react-dom": "19.2.6",
    "react-ga4": "^3.0.1",
    "react-github-calendar": "^5.0.6",
    "react-icons": "^5.5.0",
    "react-router-dom": "^7.15.1",
    "styled-components": "^6.1.13",
    "styletron-engine-atomic": "^1.5.0",
    "styletron-react": "^6.1.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "gh-pages": "^6.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "prettier": "^3.4.2",
    "prettier-package-json": "^2.8.0",
    "vite": "^6.0.7"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "lint-staged": {
    "*.json": "prettier-package-json --write",
    "*.{js,css,md}": "prettier --write"
  },
  "overrides": {
    "node-fetch": "^2.6.7",
    "moment-timezone": "^0.5.46"
  }
}
